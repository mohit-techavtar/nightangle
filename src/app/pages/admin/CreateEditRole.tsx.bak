import React, { useState } from "react";
import { useNavigate, useSearchParams } from "react-router";
import {
  Shield, Check, ChevronLeft, AlertCircle, Lock, Users, Settings,
  PhoneCall, MessageCircle, Mail, Megaphone, BarChart3, DollarSign, FileText, Briefcase
} from "lucide-react";

interface PermissionModule {
  id: string;
  name: string;
  icon: React.ElementType;
  permissions: Permission[];
}

interface Permission {
  id: string;
  name: string;
  description: string;
  category: "read" | "write" | "delete" | "admin";
}

const permissionModules: PermissionModule[] = [
  {
    id: "crm",
    name: "CRM",
    icon: Users,
    permissions: [
      { id: "crm_read", name: "View CRM Data", description: "View leads, contacts, companies, and deals", category: "read" },
      { id: "crm_create", name: "Create Records", description: "Create new leads, contacts, and companies", category: "write" },
      { id: "crm_update", name: "Update Records", description: "Edit existing CRM records", category: "write" },
      { id: "crm_delete", name: "Delete Records", description: "Delete CRM records", category: "delete" },
      { id: "crm_export", name: "Export Data", description: "Export CRM data to CSV/Excel", category: "write" },
      { id: "crm_import", name: "Import Data", description: "Import bulk data into CRM", category: "write" },
    ]
  },
  {
    id: "ai_calling",
    name: "AI Calling",
    icon: PhoneCall,
    permissions: [
      { id: "call_view", name: "View Campaigns", description: "View AI calling campaigns and logs", category: "read" },
      { id: "call_create", name: "Create Campaigns", description: "Create new AI calling campaigns", category: "write" },
      { id: "call_monitor", name: "Live Monitoring", description: "Access live call monitoring dashboard", category: "read" },
      { id: "call_config", name: "Configure Agents", description: "Configure AI agents and prompts", category: "write" },
      { id: "call_analytics", name: "View Analytics", description: "Access call analytics and reports", category: "read" },
      { id: "call_admin", name: "Admin Settings", description: "Manage system-wide calling settings", category: "admin" },
    ]
  },
  {
    id: "campaigns",
    name: "Campaigns",
    icon: Megaphone,
    permissions: [
      { id: "camp_view", name: "View Campaigns", description: "View all campaign data", category: "read" },
      { id: "camp_create", name: "Create Campaigns", description: "Create multi-channel campaigns", category: "write" },
      { id: "camp_edit", name: "Edit Campaigns", description: "Modify existing campaigns", category: "write" },
      { id: "camp_delete", name: "Delete Campaigns", description: "Delete campaigns", category: "delete" },
      { id: "camp_send", name: "Send Campaigns", description: "Send and schedule campaigns", category: "write" },
      { id: "camp_analytics", name: "View Analytics", description: "Access campaign performance data", category: "read" },
    ]
  },
  {
    id: "communication",
    name: "Communication",
    icon: MessageCircle,
    permissions: [
      { id: "comm_whatsapp", name: "WhatsApp Access", description: "Access WhatsApp module", category: "read" },
      { id: "comm_sms", name: "SMS Access", description: "Access SMS module", category: "read" },
      { id: "comm_email", name: "Email Access", description: "Access Email module", category: "read" },
      { id: "comm_send", name: "Send Messages", description: "Send messages across all channels", category: "write" },
      { id: "comm_templates", name: "Manage Templates", description: "Create and edit message templates", category: "write" },
    ]
  },
  {
    id: "analytics",
    name: "Reports & Analytics",
    icon: BarChart3,
    permissions: [
      { id: "analytics_view", name: "View Reports", description: "Access all reports and dashboards", category: "read" },
      { id: "analytics_create", name: "Create Reports", description: "Build custom reports", category: "write" },
      { id: "analytics_export", name: "Export Reports", description: "Export reports and data", category: "write" },
      { id: "analytics_share", name: "Share Reports", description: "Share reports with team members", category: "write" },
    ]
  },
  {
    id: "billing",
    name: "Billing",
    icon: DollarSign,
    permissions: [
      { id: "billing_view", name: "View Billing", description: "View invoices and usage", category: "read" },
      { id: "billing_manage", name: "Manage Billing", description: "Create invoices and manage credits", category: "write" },
      { id: "billing_config", name: "Configure Rates", description: "Set billing rates and rules", category: "admin" },
    ]
  },
  {
    id: "admin",
    name: "Administration",
    icon: Settings,
    permissions: [
      { id: "admin_users", name: "Manage Users", description: "Create, edit, and delete users", category: "admin" },
      { id: "admin_roles", name: "Manage Roles", description: "Create and modify roles and permissions", category: "admin" },
      { id: "admin_tenants", name: "Manage Tenants", description: "Manage tenant accounts", category: "admin" },
      { id: "admin_settings", name: "System Settings", description: "Configure platform settings", category: "admin" },
      { id: "admin_audit", name: "View Audit Logs", description: "Access audit and compliance logs", category: "read" },
    ]
  },
];

const steps = [
  { id: 1, name: "Basic Information", icon: FileText },
  { id: 2, name: "Module Permissions", icon: Lock },
  { id: 3, name: "Review & Create", icon: Check },
];

export function CreateEditRole() {
  const navigate = useNavigate();
  const [searchParams] = useSearchParams();
  const isEdit = searchParams.has("id");
  const [currentStep, setCurrentStep] = useState(1);
  const [showSuccessModal, setShowSuccessModal] = useState(false);

  const [formData, setFormData] = useState({
    name: "",
    description: "",
    type: "custom" as "system" | "custom",
    permissions: [] as string[],
  });

  const [errors, setErrors] = useState<Record<string, string>>({});

  const handleNext = () => {
    if (currentStep === 1) {
      const newErrors: Record<string, string> = {};
      if (!formData.name.trim()) newErrors.name = "Role name is required";
      if (!formData.description.trim()) newErrors.description = "Description is required";

      if (Object.keys(newErrors).length > 0) {
        setErrors(newErrors);
        return;
      }
      setErrors({});
    }

    if (currentStep === 2) {
      if (formData.permissions.length === 0) {
        setErrors({ permissions: "Please select at least one permission" });
        return;
      }
      setErrors({});
    }

    if (currentStep < 3) {
      setCurrentStep(currentStep + 1);
    }
  };

  const handleBack = () => {
    if (currentStep > 1) {
      setCurrentStep(currentStep - 1);
    } else {
      navigate("/admin/roles-permissions/roles");
    }
  };

  const handleSubmit = () => {
    console.log("Creating/Updating role:", formData);
    setShowSuccessModal(true);
  };

  const togglePermission = (permissionId: string) => {
    setFormData(prev => ({
      ...prev,
      permissions: prev.permissions.includes(permissionId)
        ? prev.permissions.filter(id => id !== permissionId)
        : [...prev.permissions, permissionId]
    }));
    setErrors({});
  };

  const toggleModule = (moduleId: string) => {
    const module = permissionModules.find(m => m.id === moduleId);
    if (!module) return;

    const modulePermissions = module.permissions.map(p => p.id);
    const allSelected = modulePermissions.every(id => formData.permissions.includes(id));

    if (allSelected) {
      setFormData(prev => ({
        ...prev,
        permissions: prev.permissions.filter(id => !modulePermissions.includes(id))
      }));
    } else {
      setFormData(prev => ({
        ...prev,
        permissions: [...new Set([...prev.permissions, ...modulePermissions])]
      }));
    }
  };

  const getCategoryColor = (category: string) => {
    switch (category) {
      case "read": return "bg-blue-50 text-blue-700";
      case "write": return "bg-green-50 text-green-700";
      case "delete": return "bg-red-50 text-red-700";
      case "admin": return "bg-purple-50 text-purple-700";
      default: return "bg-gray-50 text-gray-700";
    }
  };

  return (
    <div className="h-screen overflow-y-auto bg-white">
      {/* Header */}
      <div className="border-b border-gray-200 bg-white sticky top-0 z-10">
        <div className="px-8 py-6">
          <button
            onClick={handleBack}
            className="flex items-center gap-2 text-sm text-[#64748B] hover:text-[#0F1B2D] mb-4"
          >
            <ChevronLeft size={18} />
            Back to {currentStep === 1 ? "Roles" : "Previous Step"}
          </button>
          <div>
            <h1 className="font-semibold text-[#0F1B2D] mb-1">
              {isEdit ? "Edit Role" : "Create New Role"}
            </h1>
            <p className="text-sm text-[#64748B]">
              {currentStep === 1 && "Define role details and basic information"}
              {currentStep === 2 && "Configure module-level permissions"}
              {currentStep === 3 && "Review and confirm role configuration"}
            </p>
          </div>
        </div>

        {/* Progress Steps */}
        <div className="px-8 pb-6">
          <div className="flex items-center justify-between max-w-2xl">
            {steps.map((step, index) => (
              <React.Fragment key={step.id}>
                <div className="flex items-center gap-3">
                  <div
                    className={`w-10 h-10 rounded-full flex items-center justify-center border-2 transition-all ${
                      currentStep > step.id
                        ? "bg-[#1565C0] border-[#1565C0] text-white"
                        : currentStep === step.id
                        ? "border-[#1565C0] text-[#1565C0] bg-white"
                        : "border-gray-300 text-gray-400 bg-white"
                    }`}
                  >
                    {currentStep > step.id ? (
                      <Check size={20} strokeWidth={2.5} />
                    ) : (
                      <step.icon size={20} />
                    )}
                  </div>
                  <div>
                    <div
                      className={`text-sm font-medium ${
                        currentStep >= step.id ? "text-[#0F1B2D]" : "text-gray-400"
                      }`}
                    >
                      {step.name}
                    </div>
                    <div className="text-xs text-[#64748B]">Step {step.id} of {steps.length}</div>
                  </div>
                </div>
                {index < steps.length - 1 && (
                  <div
                    className={`flex-1 h-0.5 mx-4 ${
                      currentStep > step.id ? "bg-[#1565C0]" : "bg-gray-300"
                    }`}
                  />
                )}
              </React.Fragment>
            ))}
          </div>
        </div>
      </div>

      <div className="p-8 max-w-4xl">
        {/* Step 1: Basic Information */}
        {currentStep === 1 && (
          <div className="space-y-6">
            <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 flex items-start gap-3">
              <AlertCircle size={20} className="text-blue-600 shrink-0 mt-0.5" />
              <div className="text-sm text-blue-900">
                <strong>Role Configuration Guidelines:</strong> Create roles based on job functions, not individual users.
                Use descriptive names that clearly indicate the role's purpose and scope.
              </div>
            </div>

            <div>
              <label className="block text-sm font-medium text-[#0F1B2D] mb-2">
                Role Name <span className="text-red-500">*</span>
              </label>
              <input
                type="text"
                value={formData.name}
                onChange={(e) => setFormData({ ...formData, name: e.target.value })}
                placeholder="e.g., Regional Sales Manager, Campaign Coordinator"
                className={`w-full h-11 px-4 rounded-lg border text-sm focus:outline-none focus:ring-2 focus:ring-[#1565C0] focus:border-transparent ${
                  errors.name ? "border-red-300" : "border-gray-300"
                }`}
              />
              {errors.name && (
                <p className="mt-1.5 text-xs text-red-600 flex items-center gap-1">
                  <AlertCircle size={12} />
                  {errors.name}
                </p>
              )}
            </div>

            <div>
              <label className="block text-sm font-medium text-[#0F1B2D] mb-2">
                Description <span className="text-red-500">*</span>
              </label>
              <textarea
                value={formData.description}
                onChange={(e) => setFormData({ ...formData, description: e.target.value })}
                placeholder="Describe the role's responsibilities and access scope..."
                rows={4}
                className={`w-full px-4 py-3 rounded-lg border text-sm focus:outline-none focus:ring-2 focus:ring-[#1565C0] focus:border-transparent resize-none ${
                  errors.description ? "border-red-300" : "border-gray-300"
                }`}
              />
              {errors.description && (
                <p className="mt-1.5 text-xs text-red-600 flex items-center gap-1">
                  <AlertCircle size={12} />
                  {errors.description}
                </p>
              )}
            </div>

            <div>
              <label className="block text-sm font-medium text-[#0F1B2D] mb-3">
                Role Type
              </label>
              <div className="grid grid-cols-2 gap-4">
                <button
                  onClick={() => setFormData({ ...formData, type: "custom" })}
                  className={`p-4 rounded-lg border-2 text-left transition-all ${
                    formData.type === "custom"
                      ? "border-[#1565C0] bg-[#1565C0]/5"
                      : "border-gray-300 hover:border-gray-400"
                  }`}
                >
                  <div className="flex items-center gap-2 mb-2">
                    <Shield size={20} className={formData.type === "custom" ? "text-[#1565C0]" : "text-gray-400"} />
                    <span className="font-medium text-[#0F1B2D]">Custom Role</span>
                  </div>
                  <p className="text-xs text-[#64748B]">
                    User-defined role with customizable permissions
                  </p>
                </button>
                <button
                  onClick={() => setFormData({ ...formData, type: "system" })}
                  disabled
                  className="p-4 rounded-lg border-2 text-left opacity-50 cursor-not-allowed border-gray-300"
                >
                  <div className="flex items-center gap-2 mb-2">
                    <Lock size={20} className="text-gray-400" />
                    <span className="font-medium text-[#0F1B2D]">System Role</span>
                  </div>
                  <p className="text-xs text-[#64748B]">
                    Built-in role (Admin only)
                  </p>
                </button>
              </div>
            </div>
          </div>
        )}

        {/* Step 2: Permissions */}
        {currentStep === 2 && (
          <div className="space-y-6">
            <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 flex items-start gap-3">
              <AlertCircle size={20} className="text-blue-600 shrink-0 mt-0.5" />
              <div className="text-sm text-blue-900">
                <strong>Permission Levels:</strong> Read (view only), Write (create/edit), Delete (remove data), Admin (full control).
                Grant minimum required access.
              </div>
            </div>

            {errors.permissions && (
              <div className="bg-red-50 border border-red-200 rounded-lg p-4 flex items-start gap-3">
                <AlertCircle size={20} className="text-red-600 shrink-0 mt-0.5" />
                <div className="text-sm text-red-900">{errors.permissions}</div>
              </div>
            )}

            <div className="space-y-4">
              {permissionModules.map((module) => {
                const modulePermissions = module.permissions.map(p => p.id);
                const selectedCount = modulePermissions.filter(id => formData.permissions.includes(id)).length;
                const allSelected = selectedCount === modulePermissions.length;

                return (
                  <div key={module.id} className="bg-white border border-gray-200 rounded-lg overflow-hidden">
                    <div className="p-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                      <div className="flex items-center gap-3">
                        <module.icon size={20} className="text-[#1565C0]" />
                        <span className="font-medium text-[#0F1B2D]">{module.name}</span>
                        <span className="text-xs text-[#64748B]">
                          {selectedCount} of {modulePermissions.length} selected
                        </span>
                      </div>
                      <button
                        onClick={() => toggleModule(module.id)}
                        className="text-xs font-medium text-[#1565C0] hover:underline"
                      >
                        {allSelected ? "Deselect All" : "Select All"}
                      </button>
                    </div>
                    <div className="divide-y divide-gray-200">
                      {module.permissions.map((permission) => (
                        <label
                          key={permission.id}
                          className="flex items-start gap-3 p-4 hover:bg-gray-50 cursor-pointer"
                        >
                          <input
                            type="checkbox"
                            checked={formData.permissions.includes(permission.id)}
                            onChange={() => togglePermission(permission.id)}
                            className="mt-0.5 w-4 h-4 rounded border-gray-300 text-[#1565C0] focus:ring-[#1565C0]"
                          />
                          <div className="flex-1">
                            <div className="flex items-center gap-2 mb-1">
                              <span className="font-medium text-sm text-[#0F1B2D]">{permission.name}</span>
                              <span className={`px-2 py-0.5 rounded text-xs font-medium ${getCategoryColor(permission.category)}`}>
                                {permission.category}
                              </span>
                            </div>
                            <p className="text-xs text-[#64748B]">{permission.description}</p>
                          </div>
                        </label>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* Step 3: Review */}
        {currentStep === 3 && (
          <div className="space-y-6">
            <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 flex items-start gap-3">
              <AlertCircle size={20} className="text-blue-600 shrink-0 mt-0.5" />
              <div className="text-sm text-blue-900">
                Review the role configuration carefully before creating. You can edit these settings later if needed.
              </div>
            </div>

            {/* Basic Info Summary */}
            <div className="bg-white border border-gray-200 rounded-lg p-6">
              <h3 className="font-semibold text-[#0F1B2D] mb-4">Role Information</h3>
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <div className="text-xs text-[#64748B] mb-1">Role Name</div>
                  <div className="font-medium text-[#0F1B2D]">{formData.name}</div>
                </div>
                <div>
                  <div className="text-xs text-[#64748B] mb-1">Type</div>
                  <div>
                    <span className={`px-2 py-1 rounded text-xs font-medium ${
                      formData.type === "system" ? "text-purple-600 bg-purple-50" : "text-blue-600 bg-blue-50"
                    }`}>
                      {formData.type.charAt(0).toUpperCase() + formData.type.slice(1)}
                    </span>
                  </div>
                </div>
                <div className="col-span-2">
                  <div className="text-xs text-[#64748B] mb-1">Description</div>
                  <div className="text-sm text-[#0F1B2D]">{formData.description}</div>
                </div>
              </div>
            </div>

            {/* Permissions Summary */}
            <div className="bg-white border border-gray-200 rounded-lg p-6">
              <div className="flex items-center justify-between mb-4">
                <h3 className="font-semibold text-[#0F1B2D]">Selected Permissions</h3>
                <span className="text-sm text-[#64748B]">
                  {formData.permissions.length} total permissions
                </span>
              </div>
              <div className="space-y-3">
                {permissionModules.map((module) => {
                  const modulePermissions = module.permissions.filter(p =>
                    formData.permissions.includes(p.id)
                  );
                  if (modulePermissions.length === 0) return null;

                  return (
                    <div key={module.id} className="border border-gray-200 rounded-lg p-4">
                      <div className="flex items-center gap-2 mb-3">
                        <module.icon size={18} className="text-[#1565C0]" />
                        <span className="font-medium text-[#0F1B2D]">{module.name}</span>
                        <span className="text-xs text-[#64748B]">
                          ({modulePermissions.length})
                        </span>
                      </div>
                      <div className="flex flex-wrap gap-2">
                        {modulePermissions.map((permission) => (
                          <span
                            key={permission.id}
                            className={`px-2 py-1 rounded text-xs font-medium ${getCategoryColor(permission.category)}`}
                          >
                            {permission.name}
                          </span>
                        ))}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        )}

        {/* Navigation Buttons */}
        <div className="flex items-center justify-between mt-8 pt-6 border-t border-gray-200">
          <button
            onClick={handleBack}
            className="h-11 px-6 rounded-lg border border-gray-300 text-sm font-medium text-[#0F1B2D] hover:bg-gray-50 transition-colors"
          >
            {currentStep === 1 ? "Cancel" : "Back"}
          </button>
          <button
            onClick={currentStep === 3 ? handleSubmit : handleNext}
            className="h-11 px-6 rounded-lg bg-[#1565C0] text-white text-sm font-medium hover:bg-[#0D47A1] transition-colors"
          >
            {currentStep === 3 ? (isEdit ? "Update Role" : "Create Role") : "Continue"}
          </button>
        </div>
      </div>

      {/* Success Modal */}
      {showSuccessModal && (
        <div className="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-lg shadow-xl max-w-md w-full">
            <div className="p-6 text-center">
              <div className="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                <CheckCircle2 size={32} className="text-green-600" />
              </div>
              <h3 className="font-semibold text-[#0F1B2D] mb-2">
                Role {isEdit ? "Updated" : "Created"} Successfully
              </h3>
              <p className="text-sm text-[#64748B] mb-6">
                The role <strong>{formData.name}</strong> has been {isEdit ? "updated" : "created"} with {formData.permissions.length} permissions.
              </p>
              <div className="flex items-center gap-3">
                <button
                  onClick={() => navigate("/admin/roles-permissions/roles")}
                  className="flex-1 h-10 px-4 rounded-lg border border-gray-300 text-sm font-medium text-[#0F1B2D] hover:bg-gray-50 transition-colors"
                >
                  View All Roles
                </button>
                <button
                  onClick={() => navigate("/admin/roles-permissions/assignments")}
                  className="flex-1 h-10 px-4 rounded-lg bg-[#1565C0] text-white text-sm font-medium hover:bg-[#0D47A1] transition-colors"
                >
                  Assign Users
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
